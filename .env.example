# =============================================================================
# WaveFighter — environment variables
#
# Copy to .env.local for development, and set the same values in
# Vercel → Settings → Environment Variables for production.
#
# THE SITE BUILDS AND DEPLOYS WITH NONE OF THESE SET. Anything missing simply does not
# render — no fake phone number, no dead WhatsApp button, no contact form that silently
# swallows enquiries. Fill them in and the corresponding feature appears.
# =============================================================================

# --- Canonical origin -------------------------------------------------------
# Used for canonical URLs, Open Graph, the sitemap and structured data.
# Defaults to https://wavefighter.shop
NEXT_PUBLIC_SITE_URL=https://wavefighter.shop

# --- Contact channels -------------------------------------------------------
# Each one is optional. A channel with no value does not render anywhere on the site.

# WhatsApp: digits only, country code first, NO plus sign and NO spaces.
# Example for a UAE number +971 50 123 4567  ->  971501234567
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Displayed as-is, and also used for the tel: link (formatting is stripped automatically).
NEXT_PUBLIC_PHONE=

NEXT_PUBLIC_EMAIL=

# Setting BOTH street and city switches on LocalBusiness structured data, which is what makes
# the site eligible for local search results ("outboard motors near me"). High value.
NEXT_PUBLIC_ADDRESS_STREET=
NEXT_PUBLIC_ADDRESS_CITY=
NEXT_PUBLIC_ADDRESS_COUNTRY=AE

# Free text, e.g. "Saturday to Thursday, 9:00 - 19:00"
NEXT_PUBLIC_BUSINESS_HOURS=

# --- Contact form delivery --------------------------------------------------
# The contact form is HIDDEN unless BOTH of these are set. This is deliberate: a form that
# cannot deliver is worse than no form, because the customer believes they have reached you.
#
# Get a key at https://resend.com (free tier is ample for this volume).
# CONTACT_FROM_EMAIL must be on a domain you have verified with Resend. Until you verify
# wavefighter.shop, leave it unset and Resend's onboarding@resend.dev sender is used.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# CONTACT_FROM_EMAIL=enquiries@wavefighter.shop

# --- Content source (future) ------------------------------------------------
# The repository pattern in src/lib/content means moving to a CMS is a one-line change in
# src/lib/content/index.ts. Nothing reads this yet.
# CONTENT_PROVIDER=local
